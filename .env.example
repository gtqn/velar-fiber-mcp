# =============================================
# VELAR-Fiber — Environment Configuration
# Copy this file to .env and fill in the values
# =============================================

# --- Server ---
SERVER_PORT=8080
SERVER_ENV=development  # development | production

# --- MCP Protocol ---
MCP_SERVER_NAME=VELAR-Fiber
MCP_SERVER_VERSION=1.0.0
MCP_MAX_CONCURRENT_TASKS=50

# --- Auth (comma-separated: key:scope pairs) ---
# Scopes: all, github, docs, system, web, utils, fiber
API_KEYS=velar-key-1:all,velar-key-2:fiber,velar-key-3:docs
RATE_LIMIT_RPM=100

# --- GitHub Toolset ---
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_HOST=https://api.github.com

# --- Docs Toolset (Context7) ---
# Get free key at: https://context7.com/dashboard
CONTEXT7_API_KEY=ctx7_xxxxxxxxxxxxxxxxxxxx
CONTEXT7_BASE_URL=https://mcp.context7.com

# --- System Toolset ---
# Sandbox directory — tools can only read/write here
SYSTEM_ALLOWED_PATH=/tmp/velar-sandbox

# --- Telemetry (OpenTelemetry) ---
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=velar-fiber
